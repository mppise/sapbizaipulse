{
  "name": "sap-bizai-pulse",
  "version": "0.1.0",
  "description": "SAP BizAI Pulse — AI-domain newsletter curator and generator",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run ui:build && tsc",
    "start": "node dist/server.js",
    "dev": "ts-node --project tsconfig.json src/server.ts",
    "ui:dev": "vite --config src/ui/vite.config.ts",
    "ui:build": "vite build --config src/ui/vite.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "bootstrap": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@sap/hana-client": "*",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "markdown-it": "^14.0.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^4.0.0",
    "playwright": "^1.40.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/markdown-it": "^14.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
